# ─── Required ────────────────────────────────────────────────────────────────

# Your Discord bot token (from discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# The Discord channel ID where new markets will be posted
# Right-click a channel → Copy Channel ID (requires Developer Mode)
CHANNEL_ID=your_channel_id_here

# ─── Optional ─────────────────────────────────────────────────────────────────

# How often to check for new markets, in milliseconds.
# Default: 60000 (1 minute). Minimum recommended: 30000 (30 seconds).
POLL_INTERVAL_MS=60000
